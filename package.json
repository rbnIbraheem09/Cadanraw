{
  "name": "cadanraw",
  "productName": "Cadanraw",
  "version": "0.1.2",
  "description": "Cadanraw — a local-first whiteboard app powered by Excalidraw",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:electron": "tsc -p tsconfig.node.json && wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "dev": "concurrently -k -n vite,electron -c green,cyan \"npm:dev:renderer\" \"npm:dev:electron\"",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.node.json",
    "build": "npm run build:renderer && npm run build:electron && electron-builder",
    "rebuild-sqlite": "electron-rebuild -f -w better-sqlite3",
    "copy:fonts": "node scripts/copy-excalidraw-fonts.mjs",
    "make:icon": "electron scripts/make-icon.cjs",
    "smoke:db": "electron scripts/smoke-db.cjs",
    "postinstall": "node scripts/copy-excalidraw-fonts.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "node scripts/test-with-abi.mjs",
    "test:watch": "vitest"
  },
  "comment": "Only main-process (runtime) modules belong in dependencies; renderer libs are bundled into dist/ by Vite and live in devDependencies so electron-builder doesn't pack them.",
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "electron-store": "^7.0.3"
  },
  "devDependencies": {
    "@excalidraw/excalidraw": "0.18.1",
    "@fontsource/hanken-grotesk": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "postcss": "^8.4.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.4.0",
    "vite": "^5.1.4",
    "vitest": "^2.0.0",
    "wait-on": "^7.2.0",
    "zustand": "^5.0.13"
  }
}
